# Copy to .env (gitignored) and fill in. The key is read by `ettle standup`.
ANTHROPIC_API_KEY=sk-ant-...

# Distributed NATS bus (only the -tags nats build). Use a tls:// URL and creds
# off localhost — the bus carries your typed atoms.
# NATS_URL=tls://nats.example.com:4222
# NATS_CREDS=/path/to/ettle.creds
# ETTLE_TEAM=your-team

# gemot endpoint for contested knots (pass via -gemot, or set and read it
# yourself). Use https:// with auth in production — the crux is sensitive.
# ETTLE_GEMOT=https://gemot.example/mcp
